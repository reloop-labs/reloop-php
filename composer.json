{
    "name": "reloop/reloop-email",
    "description": "Reloop PHP SDK",
    "version": "1.8.0",
    "type": "library",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.8"
    },
    "autoload": {
        "psr-4": {
